{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WOM-kit source bindings",
  "type": "object",
  "required": ["version", "archive_id", "sources"],
  "properties": {
    "version": {"type": "string", "enum": ["source-bindings/v0.1"]},
    "archive_id": {"type": "string"},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "source_type", "enabled", "root_ref", "scope_policy", "visibility"],
        "properties": {
          "source_id": {"type": "string"},
          "source_type": {
            "type": "string",
            "enum": ["local_folder", "external_ssd", "notion_export", "google_drive_export", "object_manifest"]
          },
          "enabled": {"type": "boolean"},
          "description": {"type": "string"},
          "root_ref": {"type": "string"},
          "scope_policy": {"type": "object"},
          "visibility": {"type": "object"},
          "provenance": {"type": "object"}
        }
      }
    }
  }
}
