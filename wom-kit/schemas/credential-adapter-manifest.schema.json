{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/wom-kit/credential-adapter-manifest.schema.json",
  "title": "WOM Credential Adapter Manifest",
  "type": "object",
  "required": [
    "schema",
    "manifest_kind",
    "manifest_version",
    "archive_id",
    "adapter_id",
    "adapter_kind",
    "adapter_family",
    "store_kind",
    "platform",
    "consumer",
    "expected_ref_prefixes",
    "supported_operations",
    "requires",
    "privacy_contract",
    "closed_actions"
  ],
  "properties": {
    "schema": {
      "const": "wom-kit/credential-adapter-manifest/v0.1"
    },
    "manifest_kind": {
      "const": "credential_adapter_manifest"
    },
    "manifest_version": {
      "const": "v0.1"
    },
    "archive_id": {
      "type": "string"
    },
    "adapter_id": {
      "type": "string"
    },
    "adapter_kind": {
      "type": "string",
      "enum": [
        "bitwarden_cli",
        "browser_platform_manager",
        "developer_secret_manager",
        "environment_injection",
        "future_wallet",
        "keepassxc_cli",
        "linux_secret_service",
        "macos_keychain",
        "onepassword_cli",
        "windows_credential_manager"
      ]
    },
    "adapter_family": {
      "type": "string"
    },
    "store_kind": {
      "type": "string",
      "enum": [
        "browser_platform_manager",
        "developer_secret_manager",
        "environment",
        "future_wallet",
        "os_keyring",
        "password_manager"
      ]
    },
    "platform": {
      "type": "string",
      "enum": [
        "cross_platform",
        "linux",
        "macos",
        "windows"
      ]
    },
    "consumer": {
      "type": "string"
    },
    "expected_ref_prefixes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supported_operations": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "browser_login_fill",
          "list_metadata_only",
          "plaintext_secret_migration",
          "resolve_for_approved_action",
          "rotate_secret",
          "write_new_secret"
        ]
      }
    },
    "requires": {
      "type": "object",
      "required": [
        "policy_gate_before_use",
        "approval_receipt_before_use",
        "local_human_ui_for_secret_writes",
        "non_echo_contract",
        "audit_receipt_after_use"
      ],
      "properties": {
        "policy_gate_before_use": {
          "type": "boolean"
        },
        "approval_receipt_before_use": {
          "type": "boolean"
        },
        "local_human_ui_for_secret_writes": {
          "type": "boolean"
        },
        "non_echo_contract": {
          "type": "boolean"
        },
        "audit_receipt_after_use": {
          "type": "boolean"
        }
      }
    },
    "privacy_contract": {
      "type": "object",
      "required": [
        "secret_values_in_manifest",
        "exact_credential_refs_in_manifest",
        "local_absolute_paths_in_manifest",
        "provider_account_values_in_manifest",
        "provider_urls_in_manifest",
        "ai_visible_secret_output_allowed"
      ],
      "properties": {
        "secret_values_in_manifest": {
          "type": "boolean"
        },
        "exact_credential_refs_in_manifest": {
          "type": "boolean"
        },
        "local_absolute_paths_in_manifest": {
          "type": "boolean"
        },
        "provider_account_values_in_manifest": {
          "type": "boolean"
        },
        "provider_urls_in_manifest": {
          "type": "boolean"
        },
        "ai_visible_secret_output_allowed": {
          "type": "boolean"
        }
      }
    },
    "closed_actions": {
      "type": "object",
      "required": [
        "adapter_manifest_written",
        "secret_value_read",
        "secret_value_written",
        "password_manager_opened",
        "browser_password_store_opened",
        "os_keyring_opened",
        "environment_read",
        "plaintext_file_read",
        "provider_api_called"
      ],
      "properties": {
        "adapter_manifest_written": {
          "type": "boolean"
        },
        "secret_value_read": {
          "type": "boolean"
        },
        "secret_value_written": {
          "type": "boolean"
        },
        "password_manager_opened": {
          "type": "boolean"
        },
        "browser_password_store_opened": {
          "type": "boolean"
        },
        "os_keyring_opened": {
          "type": "boolean"
        },
        "environment_read": {
          "type": "boolean"
        },
        "plaintext_file_read": {
          "type": "boolean"
        },
        "provider_api_called": {
          "type": "boolean"
        }
      }
    }
  }
}
