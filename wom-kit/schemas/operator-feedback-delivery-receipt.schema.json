{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WOM-kit operator feedback delivery-boundary receipt",
  "type": "object",
  "required": [
    "schema",
    "dry_run",
    "approved",
    "reviewed_by",
    "delivered_feedback_ids",
    "delivered_count",
    "skipped_unreadable_count",
    "only",
    "external_submission_performed",
    "delivery_is_metadata_only",
    "created_at"
  ],
  "properties": {
    "schema": {"type": "string", "const": "wom-kit/operator-feedback-delivery-receipt/v0.1"},
    "dry_run": {"type": "boolean"},
    "approved": {"type": "boolean"},
    "reviewed_by": {"type": ["string", "null"]},
    "delivered_feedback_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "delivered_count": {"type": "integer"},
    "skipped_unreadable_count": {"type": "integer"},
    "only": {"type": ["string", "null"]},
    "batch_digest": {"type": "string"},
    "external_submission_performed": {"type": "boolean", "const": false},
    "delivery_is_metadata_only": {"type": "boolean", "const": true},
    "created_at": {"type": "string"}
  }
}
