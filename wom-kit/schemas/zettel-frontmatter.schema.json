{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WOM-kit zettel frontmatter",
  "type": "object",
  "required": ["id", "title", "created_at", "updated_at", "archive_id", "status", "facets", "assets", "edges", "provenance", "visibility"],
  "properties": {
    "id": {"type": "string"},
    "title": {"type": "string"},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "archive_id": {"type": "string"},
    "status": {"type": "string", "enum": ["draft", "canonical", "archived", "redacted"]},
    "kind": {"type": "string"},
    "facets": {"type": "object"},
    "assets": {"type": "array"},
    "edges": {"type": "array"},
    "provenance": {
      "type": "object",
      "required": ["created_by", "created_in", "source", "derived_from"],
      "properties": {
        "created_by": {"type": "string"},
        "created_in": {"type": "string"},
        "source": {"type": "string"},
        "creation_mode": {
          "type": "string",
          "enum": ["human_written", "ai_assisted", "ai_generated", "imported", "derived"]
        },
        "assisted_by": {"type": "array", "items": {"type": "string"}},
        "supervised_by": {"type": "array", "items": {"type": "string"}},
        "derived_from": {"type": "array"}
      }
    },
    "visibility": {
      "type": "object",
      "required": ["scope", "allowed_archives", "source_visibility"],
      "properties": {
        "scope": {"type": "string"},
        "allowed_archives": {"type": "array"},
        "source_visibility": {"type": "string"}
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {"type": "string"},
          "value": {"type": "string"},
          "role": {"type": "string"}
        },
        "required": ["type", "value"]
      }
    },
    "local_ai_sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "runtime": {"type": "string"},
          "session_ref": {"type": "string"},
          "profile_id": {"type": "string"},
          "archive_id": {"type": "string"},
          "authority_mode": {"type": "string"}
        },
        "required": ["session_ref"]
      }
    },
    "source_intake": {
      "type": "object",
      "properties": {
        "plan_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "input_kind": {"type": "string"},
        "source_kind": {"type": ["string", "null"]},
        "objet_status": {"type": ["string", "null"]},
        "object_storage_configured": {"type": "boolean"},
        "content_access": {
          "type": "object",
          "properties": {
            "metadata_only": {"type": "boolean"},
            "content_read": {"type": "boolean"},
            "copied": {"type": "boolean"},
            "uploaded": {"type": "boolean"},
            "imported": {"type": "boolean"},
            "ocr_performed": {"type": "boolean"},
            "transcription_performed": {"type": "boolean"},
            "external_api_called": {"type": "boolean"},
            "full_hash_calculated": {"type": "boolean"}
          }
        }
      }
    },
    "prompt_boundary": {
      "type": "object",
      "properties": {
        "checked": {"type": "boolean"},
        "report_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
        "source_kind": {"type": ["string", "null"], "enum": ["inline_text", "archive_path", null]},
        "source_path": {"type": ["string", "null"]},
        "untrusted_text_boundary": {"type": "boolean"},
        "external_text_can_command": {"type": "boolean"},
        "detected_pattern_ids": {"type": "array", "items": {"type": "string"}},
        "handling_note": {"type": "string"}
      }
    },
    "draft_creation": {
      "type": "object",
      "properties": {
        "approved_by": {"type": ["string", "null"]},
        "approval_scope": {"type": "string", "enum": ["inbox_draft_only"]},
        "approved_body_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "promotion": {"type": "object"},
    "mint": {"type": "object"}
  }
}
