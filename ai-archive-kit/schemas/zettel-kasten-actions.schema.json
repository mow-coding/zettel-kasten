{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Archive Kit zettel-kasten actions",
  "type": "object",
  "required": ["schema_version", "zettel_kasten_id", "status", "description", "defaults", "actions"],
  "properties": {
    "schema_version": {"type": "string"},
    "zettel_kasten_id": {"type": "string"},
    "status": {"type": "string"},
    "description": {"type": "string"},
    "defaults": {"type": "object"},
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "display_name", "status", "category", "description"],
        "properties": {
          "action_id": {"type": "string"},
          "display_name": {"type": "string"},
          "status": {"type": "string"},
          "category": {"type": "string"},
          "description": {"type": "string"}
        }
      }
    }
  }
}
