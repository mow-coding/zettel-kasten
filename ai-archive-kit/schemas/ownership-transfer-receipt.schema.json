{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Archive Kit ownership transfer receipt",
  "type": "object",
  "required": [
    "receipt_id",
    "action",
    "dry_run",
    "source_archive",
    "previous_owner",
    "new_owner",
    "operators_before",
    "operators_after",
    "scope_manifest",
    "approval_actors",
    "trust_gate",
    "ownership_gate",
    "lineage",
    "blockers",
    "warnings"
  ],
  "properties": {
    "receipt_id": {"type": "string"},
    "receipt_path": {"type": "string"},
    "action": {"type": "string", "enum": ["transfer_archive_ownership"]},
    "dry_run": {"type": "boolean"},
    "timestamp": {"type": "string"},
    "source_archive": {"type": "string"},
    "previous_owner": {
      "type": "object",
      "required": ["owner_id", "owner_kind"],
      "properties": {
        "owner_id": {"type": "string"},
        "owner_kind": {"type": "string"},
        "owner_archive_id": {"type": ["string", "null"]}
      }
    },
    "new_owner": {
      "type": "object",
      "required": ["owner_id", "owner_kind"],
      "properties": {
        "owner_id": {"type": "string"},
        "owner_kind": {"type": "string"},
        "owner_archive_id": {"type": ["string", "null"]}
      }
    },
    "operators_before": {
      "type": "array",
      "items": {"type": "string"}
    },
    "operators_after": {
      "type": "array",
      "items": {"type": "string"}
    },
    "subject": {"type": ["string", "null"]},
    "scope_manifest": {"type": "object"},
    "approval_actors": {
      "type": "array",
      "items": {"type": "string"}
    },
    "trust_gate": {"type": "object"},
    "ownership_gate": {"type": "object"},
    "lineage": {"type": "object"},
    "provider_change_plan": {"type": "object"},
    "blockers": {
      "type": "array",
      "items": {"type": "string"}
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string"}
    },
    "reviewed_by": {"type": "string"},
    "reviewed_at": {"type": "string"},
    "result": {"type": "object"}
  }
}
