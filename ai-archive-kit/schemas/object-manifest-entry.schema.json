{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Archive Kit object manifest entry",
  "type": "object",
  "required": ["object_id", "sha256", "logical_key", "locations", "provenance"],
  "properties": {
    "object_id": {"type": "string"},
    "sha256": {"type": "string"},
    "logical_key": {"type": "string"},
    "mime": {"type": "string"},
    "size_bytes": {"type": "integer"},
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider"],
        "properties": {
          "provider": {"type": "string"},
          "path": {"type": "string"},
          "availability": {"type": "string"}
        }
      }
    },
    "provenance": {"type": "object"}
  }
}
