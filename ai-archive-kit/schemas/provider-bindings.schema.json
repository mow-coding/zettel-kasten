{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Archive Kit provider bindings",
  "type": "object",
  "required": ["version", "archive_id", "bindings"],
  "properties": {
    "version": {"type": "string", "enum": ["provider-bindings/v0.1"]},
    "archive_id": {"type": "string"},
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["binding_id", "provider", "enabled", "purpose", "resource", "auth", "owner_mapping"],
        "properties": {
          "binding_id": {"type": "string"},
          "provider": {
            "type": "string",
            "enum": ["github", "cloudflare_r2", "backblaze_b2", "neon", "external_ssd", "rclone", "restic", "keepassxc"]
          },
          "enabled": {"type": "boolean"},
          "purpose": {"type": "string"},
          "resource": {"type": "object"},
          "auth": {"type": "object"},
          "owner_mapping": {"type": "object"},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
