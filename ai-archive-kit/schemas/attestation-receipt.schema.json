{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Archive Kit attestation receipt",
  "type": "object",
  "required": [
    "receipt_id",
    "receipt_path",
    "action",
    "lifecycle_action",
    "dry_run",
    "attesting_archive",
    "source_archive",
    "target_archive",
    "delegate_receipt",
    "delegated_zets",
    "trust_gate",
    "verification",
    "blockers",
    "warnings"
  ],
  "properties": {
    "receipt_id": {"type": "string"},
    "receipt_path": {"type": "string"},
    "action": {"type": "string", "enum": ["attest_zet"]},
    "lifecycle_action": {"type": "string", "enum": ["attest"]},
    "dry_run": {"type": "boolean"},
    "timestamp": {"type": "string"},
    "attesting_archive": {"type": "string"},
    "source_archive": {"type": "string"},
    "target_archive": {"type": "string"},
    "delegate_receipt": {"type": "object"},
    "delegated_zets": {
      "type": "array",
      "items": {"type": "object"}
    },
    "trust_gate": {"type": "object"},
    "verification": {"type": "object"},
    "blockers": {
      "type": "array",
      "items": {"type": "string"}
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
