{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Archive Kit zettel-kasten policies",
  "type": "object",
  "required": ["schema_version", "zettel_kasten_id", "status", "description", "policy_decisions", "policies"],
  "properties": {
    "schema_version": {"type": "string"},
    "zettel_kasten_id": {"type": "string"},
    "status": {"type": "string"},
    "description": {"type": "string"},
    "policy_decisions": {"type": "array"},
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["policy_id", "decision", "applies_to", "condition", "enforcement", "reason"],
        "properties": {
          "policy_id": {"type": "string"},
          "decision": {"type": "string"},
          "applies_to": {"type": "object"},
          "condition": {"type": "string"},
          "enforcement": {"type": "string"},
          "reason": {"type": "string"}
        }
      }
    }
  }
}
