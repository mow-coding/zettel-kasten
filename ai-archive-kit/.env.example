# AI Archive Kit Docker-first runtime settings.
# This file contains no secrets.

# Host folder mounted into the Linux container as /archives.
ARCHIVE_HOST_ROOT=./archives

# Non-root runtime identity used inside the Linux container.
# Unix setup rewrites these to the host user's uid/gid when it creates .env.
ARCHIVE_UID=10001
ARCHIVE_GID=10001

# Used for timestamps and logs inside the container.
TZ=Asia/Seoul
